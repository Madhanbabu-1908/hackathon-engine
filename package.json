{
  "name": "hackathon-engine",
  "version": "1.0.0",
  "description": "TCS GenAI Lab Hackathon Orchestration Engine",
  "main": "launcher.cjs",
  "bin": "launcher.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "build:exe": "npm run build:client && npx @yao-pkg/pkg . --targets node20-win-x64 --output dist-exe/HackathonEngine.exe"
  },
  "pkg": {
    "assets": [
      "client/dist/**/*",
      "server/node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist-exe",
    "icon": "assets/icon.ico"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@yao-pkg/pkg": "^5.11.1"
  }
}
